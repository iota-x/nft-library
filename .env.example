# Copy this file to `.env.local` and fill in the values.
# `.env.local` is git-ignored so secrets never get committed.

# Helius RPC API key (server-only — no NEXT_PUBLIC_ prefix).
# Create one at https://dashboard.helius.dev
HELIUS_API_KEY=

# Optional: Magic Eden API key (server-only). Floor-price/listing data works
# without it via the public API, but a key raises the rate limit.
# https://docs.magiceden.io
MAGIC_EDEN_API_KEY=

# Public localStorage namespace key (safe to expose).
NEXT_PUBLIC_LOCAL_STORAGE_KEY="wallet_connection"
